# Telegram bot token from @BotFather (secret — keep out of git)
BOT_TOKEN=
# SQLite file path
DB_PATH=./tnt-delivery-bot.sqlite
# Seconds per tick
TICK_SECONDS=10
# Poll period in ticks (N): each token polled once per N ticks
POLL_PERIOD_TICKS=12
# Token retention hours (refreshed on activity)
TOKEN_TTL_HOURS=24
# Consecutive fetch failures before a token is dropped + user notified
MAX_FETCH_FAILURES=5
# T&T tracking API base
API_BASE=https://tmsapi.tntsupermarket.us/track/customer
# Optional proxy for the T&T API client, e.g. http://127.0.0.1:7890
# HTTP_PROXY=
# Log level
RUST_LOG=info
